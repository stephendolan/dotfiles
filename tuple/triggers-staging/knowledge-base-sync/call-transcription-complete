#!/usr/bin/env bash
set -euo pipefail

# knowledge-base-sync: when a transcription session completes, run a headless
# Claude (sonnet) that promotes durable knowledge from the call into Stephen's
# Obsidian knowledge base, writes a call-summary.md coverage marker into the
# session folder, and commits the vault.

LOG=/tmp/tuple-trigger-debug.log
{
    printf '\n=== %s call-transcription-complete fired (knowledge-base-sync) ===\n' "$(date -u +%FT%TZ)"
    printf 'cwd=%s pid=%s argv: %s\n' "$(pwd)" "$$" "$*"
} >> "$LOG" 2>&1
trap 'printf "knowledge-base-sync: exit status=%s on line %s\n" "$?" "$LINENO" >> "$LOG"' EXIT
exec >>"$LOG" 2>&1

PATH="$HOME/.local/bin:/usr/local/bin:/opt/homebrew/bin:$PATH"

TRIGGER_DIR="$(cd "$(dirname "$0")" && pwd)"
VAULT="$HOME/Obsidian/Notes"
INSTRUCTIONS="${TRIGGER_DIR}/instructions.md"

if [ -z "${TUPLE_TRIGGER_CALL_ARTIFACTS_DIRECTORY:-}" ]; then
    echo "knowledge-base-sync: TUPLE_TRIGGER_CALL_ARTIFACTS_DIRECTORY not set" >&2
    exit 1
fi

SESSION_DIR="${TUPLE_TRIGGER_CALL_ARTIFACTS_DIRECTORY}"
CALLS_ROOT="$(dirname "${SESSION_DIR}")"
SESSION_NAME="$(basename "${SESSION_DIR}")"
CALL_ID="${SESSION_NAME#*@}"
SHORT_ID="${CALL_ID:0:8}"
TODAY="$(date +%F)"

# Gather every unprocessed session of this call (transcription can stop and
# restart mid-call, creating multiple session dirs ending @<call-id>). A
# session is processed when it carries a call-summary.md coverage marker, so
# this trigger is idempotent and also sweeps up sessions a previous firing
# missed.
SESSIONS=()
for dir in "${CALLS_ROOT}"/*@"${CALL_ID}"; do
    [ -d "${dir}" ] || continue
    [ -f "${dir}/call-summary.md" ] && continue
    if [ ! -s "${dir}/transcriptions.jsonl" ]; then
        # No transcript at all: mark it empty right here so the completeness
        # lint stays clean — not worth a Claude run.
        printf '# Call %s (%s)\n\n**Classification:** empty\n\nNo transcript was produced for this session; no knowledge to mine.\n' \
            "${SHORT_ID}" "${TODAY}" > "${dir}/call-summary.md"
        echo "knowledge-base-sync: marked transcript-less session $(basename "${dir}") as empty"
        continue
    fi
    SESSIONS+=("${dir}")
done

if [ "${#SESSIONS[@]}" -eq 0 ]; then
    echo "knowledge-base-sync: no unprocessed transcript sessions for ${SHORT_ID} — nothing to do"
    exit 0
fi

# Everything heavy runs detached: the Tuple trigger runner executes triggers
# in series, and a multi-minute Claude run here would queue every other
# trigger event (e.g. the next call's sidekick popups) behind it. Fork the
# worker, disown it, and return to the runner immediately.
SESSION_LIST="$(printf '%s\n' "${SESSIONS[@]}")"
USER_PROMPT="A Tuple call transcription session just completed. Process it into the knowledge base per your instructions.

Call ID: ${CALL_ID} (short: ${SHORT_ID})
Date: ${TODAY}
Tuple environment: ${TUPLE_TRIGGER_ENV:-staging}
Unprocessed session director$( [ "${#SESSIONS[@]}" -eq 1 ] && echo 'y' || echo 'ies' ) for this call:
${SESSION_LIST}

Process every listed session. Remember: write a call-summary.md coverage marker into each one, even if the call is a low-signal test."

(
    # Serialize vault access: two calls ending near-simultaneously must not
    # edit and commit concurrently. mkdir is atomic; stale locks (>30 min)
    # are stolen.
    LOCK="${TRIGGER_DIR}/.vault-lock"
    waited=0
    until mkdir "${LOCK}" 2>/dev/null; do
        if [ -f "${LOCK}/ts" ] && [ "$(( $(date +%s) - $(cat "${LOCK}/ts") ))" -gt 1800 ]; then
            echo "knowledge-base-sync: stealing stale vault lock"
            rm -rf "${LOCK}"
            continue
        fi
        if [ "${waited}" -ge 900 ]; then
            echo "knowledge-base-sync: gave up waiting for vault lock after 15m (call ${SHORT_ID})" >&2
            echo "knowledge-base-sync: sessions remain unmarked; the completeness lint will catch them" >&2
            exit 1
        fi
        sleep 10; waited=$((waited + 10))
    done
    date +%s > "${LOCK}/ts"
    trap 'rm -rf "${LOCK}"; printf "knowledge-base-sync: worker exit status=%s (call %s)\n" "$?" "${SHORT_ID}" >> "$LOG"' EXIT

    cd "${VAULT}"
    # Prompt goes via stdin: --allowedTools is variadic and would swallow a
    # trailing positional prompt argument.
    printf '%s' "${USER_PROMPT}" | claude \
        --model sonnet \
        --print \
        --append-system-prompt-file "${INSTRUCTIONS}" \
        --allowedTools "Read,Write,Edit,Glob,Grep,Bash(git status:*),Bash(git diff:*),Bash(git log:*),Bash(git add:*),Bash(git commit:*),Bash(obsidian:*),Bash(/Applications/Obsidian.app/Contents/MacOS/obsidian:*),Bash(pgrep:*),Bash(tuple-staging:*),Bash(tuple:*)" \
        || {
            echo "knowledge-base-sync: claude exited non-zero for call ${SHORT_ID} — see output above" >&2
            echo "knowledge-base-sync: sessions remain unmarked; the completeness lint will catch them" >&2
            exit 1
        }

    echo "knowledge-base-sync: processed ${#SESSIONS[@]} session(s) for call ${SHORT_ID}"
) >> "$LOG" 2>&1 < /dev/null &
WORKER_PID=$!
disown 2>/dev/null || true

echo "knowledge-base-sync: detached worker (pid ${WORKER_PID}) for call ${SHORT_ID}; returning to trigger runner"
